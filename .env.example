# Kopieren nach .env und Werte eintragen. .env ist gitignored.

# --- Datenbank ----------------------------------------------------------------
# Eine einzige Quelle für ALLE DB-Verbindungen (ORM + Raw SQL).
# Die URL wird im Code automatisch gebaut aus diesen Werten.
SQL_SERVER=192.168.178.2
SQL_PORT=50000
SQL_DATABASE=eazybusiness
SQL_USERNAME=
SQL_PASSWORD=

# --- JWT (shared mit toci-erp/backend/.env — muss IDENTISCH sein) -------------
SECRET_KEY=change-me-in-production
ALGORITHM=HS256

# --- Wechselkurse -------------------------------------------------------------
# Pfad zur lokalen JSON-Datei mit BMF-Umrechnungskursen.
# Default: data/exchange_rates.json (relativ zum Arbeitsverzeichnis)
# JTL_RATES_PATH=data/exchange_rates.json
